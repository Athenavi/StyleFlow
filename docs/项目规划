## 4. 数据模型设计（核心实体）

只列出关键模型字段，可根据业务需求扩展。

```python
# 用户扩展
class Profile(models.Model):
    user = OneToOneField(User)
    role = CharField(choices=['designer','pattern_maker','accountant','admin'])
    erp_user_id = CharField(...)  # ERP 关联

# 设计稿
class Design(models.Model):
    creator = ForeignKey(User)
    image_url = URLField()
    prompt = TextField()
    category = CharField(...)  # 款式、面料、灵感图
    status = CharField(default='draft')
    created_at = DateTimeField()

# 虚拟试衣记录
class TryOnTask(models.Model):
    user = ForeignKey(User)
    person_image = URLField()
    garment_image = URLField()
    result_image = URLField(null=True)
    status = CharField()  # pending, completed, failed

# 工作流实例
class WorkflowInstance(models.Model):
    workflow_type = CharField()  # 'style_development', 'costing'
    object_id = IntegerField()
    current_node = CharField()
    status = CharField(default='running')
    data = JSONField()  # 快照

# ERP 数据镜像（临时表或连接器）
class ErpStyle(models.Model):
    style_code = CharField(unique=True)
    description = TextField()
    bom = JSONField()
    # ... 其他必要字段，定期同步
```

